{
  "version": "1.7.2",
  "description": "Aether 基础设施部署 Hooks 配置 - 12个 Skills + 2个 Agents + 3个 Hooks",
  "enabled": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/cli-guard-hook.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/ci-watch-hook.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/benchmark-aggregate-hook.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "disable_with_env": "AETHER_HOOKS_DISABLED=true"
}
